generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id     Int    @id @default(autoincrement())
  nombre String
  correo String @unique
  edad   Int
}

model Product {
  id        Int    @id @default(autoincrement())
  nombre    String
  precio    Float
  stock     Int
  categoria String
}